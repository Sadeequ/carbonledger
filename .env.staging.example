# ── Staging Environment Configuration ────────────────────────────────────────
# This file contains staging-specific environment variables that use Stellar testnet
# but with separate database and contract instances from the shared testnet environment.

# ── Stellar Network (Testnet for staging) ────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Staging Contract Addresses (separate from testnet) ───────────────────────
STAGING_REGISTRY_CONTRACT_ID=
STAGING_CREDIT_CONTRACT_ID=
STAGING_MARKETPLACE_CONTRACT_ID=
STAGING_ORACLE_CONTRACT_ID=
STAGING_USDC_CONTRACT_ID=

# ── Oracle Keypair (staging-specific) ────────────────────────────────────────
ORACLE_SECRET_KEY=
ORACLE_PUBLIC_KEY=

# ── Admin Keypair (staging-specific) ─────────────────────────────────────────
ADMIN_SECRET_KEY=
ADMIN_PUBLIC_KEY=

# ── Database (separate staging database) ─────────────────────────────────────
DATABASE_URL=postgresql://carbonledger_staging:<POSTGRES_PASSWORD>@localhost:5432/carbonledger_staging
POSTGRES_PASSWORD=

# ── Prisma Connection Pool (staging optimized) ───────────────────────────────
DB_POOL_MAX=5
DB_POOL_TIMEOUT_MS=15000
DB_CONNECT_TIMEOUT_S=15

# ── Auth (staging-specific secrets) ──────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRY=7d

# ── IPFS / Pinata (can reuse or separate) ────────────────────────────────────
IPFS_API_URL=https://api.pinata.cloud
IPFS_API_KEY=
IPFS_SECRET_KEY=

# ── Satellite Data (can reuse testnet keys) ──────────────────────────────────
GOOGLE_EARTH_ENGINE_KEY=
PLANET_LABS_API_KEY=
GEE_WEBHOOK_SECRET=

# ── Price Feeds (can reuse testnet keys) ─────────────────────────────────────
XPANSIV_API_KEY=
TOUCAN_API_KEY=

# ── Verifier APIs (can reuse testnet keys) ───────────────────────────────────
GOLD_STANDARD_API_URL=
GOLD_STANDARD_API_KEY=
VERRA_VCS_API_URL=
VERRA_VCS_API_KEY=

# ── Alerts (staging-specific webhook) ────────────────────────────────────────
ADMIN_ALERT_WEBHOOK=

# ── Frontend (Next.js public vars for staging) ───────────────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_API_URL=https://staging-api.carbonledger.com/api/v1
NEXT_PUBLIC_REGISTRY_CONTRACT=
NEXT_PUBLIC_CREDIT_CONTRACT=
NEXT_PUBLIC_MARKETPLACE_CONTRACT=
NEXT_PUBLIC_ORACLE_CONTRACT=
NEXT_PUBLIC_USDC_CONTRACT=

# ── Redis (staging instance) ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Backend (staging configuration) ──────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://staging.carbonledger.com
ALLOWED_ORIGINS=https://staging.carbonledger.com,https://staging-api.carbonledger.com
BODY_SIZE_LIMIT=10kb

# ── Oracle Service (staging backend URL) ─────────────────────────────────────
BACKEND_API_URL=https://staging-api.carbonledger.com/api/v1
BACKEND_JWT_TOKEN=

# ── Staging Deployment Configuration ─────────────────────────────────────────
STAGING_URL=https://staging.carbonledger.com
STAGING_API_URL=https://staging-api.carbonledger.com/api/v1
STORYBOOK_STAGING_URL=https://storybook-staging.carbonledger.com

# ── Log Level (more verbose for staging) ─────────────────────────────────────
LOG_LEVEL=debug

# ── Grafana (staging dashboard) ──────────────────────────────────────────────
GRAFANA_PASSWORD=